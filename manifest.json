{
  "manifest_version": 3,
  "name": "YouTube In-Video Logo Remover",
  "version": "1.0",
  "description": "Automatically removes channel logos displayed on YouTube videos.",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}